APP_NAME=RememberME
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://rememberme.202.150.156.39:9080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=error

# MySQL DBaaS (CapRover internal host)
DB_CONNECTION=mysql
DB_HOST=srv-captain--kwan-app-01
DB_PORT=3306
DB_DATABASE=rememberme
DB_USERNAME=root
DB_PASSWORD=

# Local development (uncomment)
# DB_CONNECTION=sqlite
# DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=/api

# Set to false in CapRover if migrations run manually
RUN_MIGRATIONS=true
